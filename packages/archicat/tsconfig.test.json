{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "./",
    "paths": {
      "@/*": ["./src/*"],
      "@cli/*": ["./src-cli/*"],
      "@internal/*": ["./src-internal/*"],
      "@test/*": ["./test/*"]
    }
  },
  "include": ["src", "src-cli", "src-internal", "test", "vitest.config.ts", "tsdown.config.cli.ts", "tsdown.config.src.ts"],
  "exclude": ["node_modules", "dist", "test/.tmp"]
}
