{
  "name": "archicat-framework",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "build": "pnpm run clean && lerna run build",
    "typecheck": "lerna run typecheck",
    "test": "node --test --test-concurrency=1 $(find tests -name '*.test.mjs' -print | sort)",
    "publish:packages": "lerna publish from-package --yes --summary-file ./lerna-publish-summary.json"
  },
  "devDependencies": {
    "lerna": "9.0.7",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "unrun": "0.3.1"
  },
  "packageManager": "pnpm@11.7.0"
}
